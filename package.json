{
  "name": "codescrim",
  "displayName": "CodeScrim — Interactive Coding Tutorials",
  "description": "Record and play Scrimba-style interactive coding tutorials with video sync inside VSCode",
  "version": "0.1.0",
  "publisher": "codescrim",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "keywords": [
    "tutorial",
    "scrimba",
    "coding",
    "video",
    "interactive"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codescrim.startRecording",
        "title": "CodeScrim: Start Recording Tutorial",
        "category": "CodeScrim",
        "icon": "$(record-keys)"
      },
      {
        "command": "codescrim.stopRecording",
        "title": "CodeScrim: Stop Recording & Save",
        "category": "CodeScrim",
        "icon": "$(debug-stop)"
      },
      {
        "command": "codescrim.addChapter",
        "title": "CodeScrim: Add Chapter Marker",
        "category": "CodeScrim",
        "icon": "$(bookmark)"
      },
      {
        "command": "codescrim.playScrim",
        "title": "CodeScrim: Open Tutorial (.scrim)",
        "category": "CodeScrim",
        "icon": "$(play-circle)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "codescrim.startRecording",
          "when": "!codescrim.isRecording"
        },
        {
          "command": "codescrim.stopRecording",
          "when": "codescrim.isRecording"
        },
        {
          "command": "codescrim.addChapter",
          "when": "codescrim.isRecording"
        },
        {
          "command": "codescrim.playScrim"
        }
      ],
      "editor/title": [
        {
          "command": "codescrim.startRecording",
          "group": "navigation@99",
          "when": "!codescrim.isRecording"
        },
        {
          "command": "codescrim.stopRecording",
          "group": "navigation@99",
          "when": "codescrim.isRecording"
        },
        {
          "command": "codescrim.addChapter",
          "group": "navigation@98",
          "when": "codescrim.isRecording"
        },
        {
          "command": "codescrim.playScrim",
          "group": "navigation@97",
          "when": "!codescrim.isRecording"
        }
      ]
    },
    "configuration": {
      "title": "CodeScrim",
      "properties": {
        "codescrim.snapshotIntervalSeconds": {
          "type": "number",
          "default": 2,
          "description": "Minimum seconds between automatic code snapshots during recording"
        },
        "codescrim.autoOpenFiles": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open tutorial files in editor when playing"
        },
        "codescrim.maxFileSizeKb": {
          "type": "number",
          "default": 500,
          "description": "Maximum file size (KB) to snapshot during recording"
        }
      }
    },
    "languages": [
      {
        "id": "scrim",
        "aliases": [
          "Scrim Tutorial",
          "scrim"
        ],
        "extensions": [
          ".scrim"
        ],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}